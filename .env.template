# ─── Database (Neon) ──────────────────────────────────────────────────────────
# Get from: Neon dashboard → your project → Connection Details → Connection string
# Replace YOUR_ACTUAL_CONNECTION_STRING below
DATABASE_URL="postgres://your_user:your_password@crimson-field-92112482.neon.tech/neondb?sslmode=require"

# ─── Email (Resend) ───────────────────────────────────────────────────────────
# Get from: resend.com/api-keys
RESEND_API_KEY="re_your_resend_key"

# Verified sender address in Resend.
# Use onboarding@resend.dev for testing only — domain must be verified for production.
EMAIL_FROM="GreenMind Enquiry <onboarding@resend.dev>"

# Internal email address that receives new enquiry alerts.
ADMIN_EMAIL="greenmindservicesllp@gmail.com"

# Optional — reply-to address for emails sent through Resend.
EMAIL_REPLY_TO="enquiries@greenmindservices.com"

# Resend Audience ID for the newsletter list.
RESEND_AUDIENCE_ID="your_audience_id"

# ─── Sanity CMS ───────────────────────────────────────────────────────────────
# Get from: sanity.io/manage → your project → API
NEXT_PUBLIC_SANITY_PROJECT_ID="your_project_id"
NEXT_PUBLIC_SANITY_DATASET="production"

# Server-side write token — NEVER prefix with NEXT_PUBLIC_, never expose client-side.
# Get from: sanity.io/manage → your project → API → Tokens → Add API token (Editor role)
SANITY_WRITE_TOKEN="your_secure_backend_token"

# ─── Analytics ────────────────────────────────────────────────────────────────
# Google Analytics 4 — get from: analytics.google.com → Admin → Data Streams
