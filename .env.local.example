# ─── Database (Neon) ──────────────────────────────────────────────────────────
# Get from: Neon dashboard → your project → Connection Details → Connection string
# Append ?sslmode=require if not already present.
DATABASE_URL="postgres://your_user:your_password@your-neon-host.neon.tech/neondb?sslmode=require"

# ─── Email (Resend) ───────────────────────────────────────────────────────────
# Get from: resend.com/api-keys
RESEND_API_KEY="re_your_resend_key"

# Verified sender address in Resend.
# Use onboarding@resend.dev for testing only — domain must be verified for production.
EMAIL_FROM="GreenMind Services LLP <noreply@greenmindservices.com>"

# Internal email address that receives new enquiry alerts.
ADMIN_EMAIL="enquiries@greenmindservices.com"

# ─── Sanity CMS ───────────────────────────────────────────────────────────────
# Get from: sanity.io/manage → your project → API
NEXT_PUBLIC_SANITY_PROJECT_ID="your_project_id"
NEXT_PUBLIC_SANITY_DATASET="production"

# Server-side write token — NEVER prefix with NEXT_PUBLIC_, never expose client-side.
# Get from: sanity.io/manage → your project → API → Tokens → Add API token (Editor role)
SANITY_WRITE_TOKEN="your_secure_backend_token"

# ─── Analytics ────────────────────────────────────────────────────────────────
# Google Analytics 4 — get from: analytics.google.com → Admin → Data Streams
NEXT_PUBLIC_GA4_MEASUREMENT_ID="G-XXXXXXXXXX"

# ─── Security ─────────────────────────────────────────────────────────────────
# Comma-separated list of origins allowed to POST to /api/enquiry.
# Used for CSRF origin checking. Set to your production domain.
# Localhost is always allowed in development (no need to list it here).
ALLOWED_ORIGINS="https://greenmindservices.com,https://www.greenmindservices.com"

# ─── Cloudflare (deployed environment only) ───────────────────────────────────
# These are set automatically by Cloudflare Pages — do NOT set them locally.
# Listed here for documentation purposes only.
#
# RATE_LIMIT_KV     — KV namespace binding for IP-based rate limiting
#                     Bind in: Cloudflare Pages → Settings → Functions → KV namespace bindings
#                     Binding name must be exactly: RATE_LIMIT_KV
#
# CF_PAGES_URL      — Set by Cloudflare to the deployment URL (e.g. https://xyz.pages.dev)
# CF_PAGES_BRANCH   — Branch that triggered the deployment
# CF_PAGES_COMMIT_SHA — Git commit SHA of the deployment
